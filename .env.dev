# =====================
# MinIO Service
# =====================
# MinIO root username
export MINIO_ROOT_USER=root
# MinIO root password
export MINIO_ROOT_PASSWORD=123qwe!@#
# MinIO API port (host)
export MINIO_PORT=9000
# MinIO Console port (host)
export MINIO_CONSOLE_PORT=9001
# MinIO data directory on host
export MINIO_DATA_DIR=/mnt/data/100.DockerVolumes/minio

# =====================
# MongoDB Service
# =====================
# MongoDB root username
export MONGO_INITDB_ROOT_USERNAME=admin
# MongoDB root password
export MONGO_INITDB_ROOT_PASSWORD=mongodb123
# Default database to create
export MONGO_INITDB_DATABASE=default
# MongoDB data directory in container
export MONGODB_DATA_DIR=/data/db
# MongoDB log directory in container
export MONDODB_LOG_DIR=/dev/null
# MongoDB port (host)
export MONGO_PORT=27018
# MongoDB data directory on host
export MONGO_DATA_DIR=/mnt/data/100.DockerVolumes/mongodb

# =====================
# Monitoring & Auxiliary Services Ports
# (Add these to docker-compose.yml if you want to parameterize ports)
# =====================
export PROMETHEUS_PORT=9090
export GRAFANA_PORT=5000
export NODE_EXPORTER_PORT=9100
export NVIDIA_DCGM_EXPORTER_PORT=9400
export CADVISOR_PORT=8080
export REDIS_PORT=6379
export PORTAINER_PORT=9009
export PORTAINER_AGENT_PORT=9010

# Ollama Configuration
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0
OLLAMA_MODELS_VOLUME=/mnt/data/100.DockerVolumes/ollama/models
OLLAMA_DATA_VOLUME=/mnt/data/100.DockerVolumes/ollama/data
OLLAMA_API_KEY="eaaf29174a113a5bf53906e858d3e047d6115423fec3ee115e7a33a12a7bf3e3"
NODE_TLS_REJECT_UNAUTHORIZED=0
# Open WebUI Configuration
OPENWEBUI_PORT=8081
OPENWEBUI_DATA_VOLUME=/mnt/data/100.DockerVolumes/open-webui

# =====================
# LiveKit Service
# =====================
export LK_API_KEY=devkey
export LK_API_SECRET=livekit_secret_key_1234567890_32
export LIVEKIT_PORT=7880
export HOST=192.168.196.2

# =====================
# PostgreSQL Service
# =====================
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=postgres
export POSTGRES_DB=pz_mothership
export POSTGRES_PORT=5432
export POSTGRES_DATA_DIR=/mnt/data/100.DockerVolumes/postgres
