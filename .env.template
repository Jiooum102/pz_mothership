# =====================
# MinIO Service
# =====================
# MinIO root username
export MINIO_ROOT_USER=<minio-root-user>
# MinIO root password
export MINIO_ROOT_PASSWORD=<minio-root-password>
# MinIO API port (host)
export MINIO_PORT=9000
# MinIO Console port (host)
export MINIO_CONSOLE_PORT=9001
# MinIO data directory on host
export MINIO_DATA_DIR=<minio-data-dir>

# =====================
# MongoDB Service
# =====================
# MongoDB root username
export MONGO_INITDB_ROOT_USERNAME=<mongo-root-username>
# MongoDB root password
export MONGO_INITDB_ROOT_PASSWORD=<mongo-root-password>
# Default database to create
export MONGO_INITDB_DATABASE=<mongo-database>
# MongoDB data directory in container
export MONGODB_DATA_DIR=<mongodb-data-dir>
# MongoDB log directory in container
export MONDODB_LOG_DIR=<mongodb-log-dir>
# MongoDB port (host)
export MONGO_PORT=<mongo-port>
# MongoDB data directory on host
export MONGO_DATA_DIR=<mongo-data-dir>

# =====================
# Monitoring & Auxiliary Services Ports
# (Add these to docker-compose.yml if you want to parameterize ports)
# =====================
export PROMETHEUS_PORT=<prometheus-port>
export GRAFANA_PORT=<grafana-port>
export NODE_EXPORTER_PORT=<node-exporter-port>
export NVIDIA_DCGM_EXPORTER_PORT=<nvidia-dcgm-exporter-port>
export CADVISOR_PORT=<cadvisor-port>
export REDIS_PORT=<redis-port>
export PORTAINER_PORT=<portainer-port>
export PORTAINER_AGENT_PORT=<portainer-agent-port>


# Ollama Configuration
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0
OLLAMA_MODELS_VOLUME=<ollama-models-volume>
OLLAMA_DATA_VOLUME=<ollama-data-volume>
OLLAMA_API_KEY=<ollama-api-key>
NODE_TLS_REJECT_UNAUTHORIZED=0
# Open WebUI Configuration
OPENWEBUI_PORT=8081
OPENWEBUI_DATA_VOLUME=<open-webui-data-volume>

# =====================
# LiveKit Service
# =====================
# LiveKit API key
export LK_API_KEY=<lk-api-key>
# LiveKit API secret
export LK_API_SECRET=<lk-api-secret>
# LiveKit port (default 7880)
export LIVEKIT_PORT=7880
# Public IP or Hostname of the server (for node-ip advertisement)
export HOST=<host-ip-or-domain>

# =====================
# PostgreSQL Service
# =====================
# PostgreSQL root username
export POSTGRES_USER=<postgres-user>
# PostgreSQL root password
export POSTGRES_PASSWORD=<postgres-password>
# Default database to create
export POSTGRES_DB=<postgres-database>
# PostgreSQL port (host)
export POSTGRES_PORT=5432
# PostgreSQL data directory on host
export POSTGRES_DATA_DIR=<postgres-data-dir>